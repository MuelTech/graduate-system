// ═══════════════════════════════════════════════════════════════════════════
// EARIST Graduate School Information System — Prisma Schema
// Schema v8  |  MySQL  |  2026-06-03
// 49 tables across 8 modules
// ═══════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 1 — CORE & USERS  (8 tables)
// users · students · panelists · programs · custom_roles ·
// role_feature_access · residency_tracking · curriculum_waivers
// ═══════════════════════════════════════════════════════════════════════════

model User {
  id           String   @id @default(uuid()) @map("user_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(APPLICANT)
  customRoleId String?  @map("custom_role_id")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // ── Profile extensions ──
  customRole   CustomRole? @relation("UserCustomRole", fields: [customRoleId], references: [id])
  student      Student?
  panelist     Panelist?

  // ── Custom-role management ──
  customRolesCreated CustomRole[] @relation("CustomRoleCreatedBy")

  // ── Curriculum waivers ──
  curriculumWaiversRecommended CurriculumWaiver[] @relation("WaiverRecommendedBy")
  curriculumWaiversApproved    CurriculumWaiver[] @relation("WaiverApprovedBy")

  // ── Bridging waivers (applicant pipeline) ──
  bridgingWaiversValidated ApplicantBridgingWaiver[] @relation("BridgingWaiverValidatedBy")

  // ── Examination ──
  entranceExamScoresGraded EntranceExamScore[] @relation("ExamScoreGradedBy")

  // ── Notifications ──
  notifications Notification[]

  // ── COR & OCR ──
  corRecordsVerified CorRecord[] @relation("CorRecordVerifiedBy")

  // ── Requirements ──
  studentRequirementsReviewed StudentRequirement[] @relation("RequirementReviewedBy")

  // ── Adviser flow ──
  adviserRequestsAsRequestedPanelist AdviserRequest[]   @relation("AdviserRequestedPanelist")
  adviserRequestsApproved            AdviserRequest[]   @relation("AdviserRequestApprovedBy")
  adviserAssignments                 AdviserAssignment[] @relation("AdviserAssigned")

  // ── Defense ──
  defenseSchedulesSet         DefenseSchedule[] @relation("ScheduleSetBy")
  panelAssignments            PanelAssignment[]
  oralExamSummariesAttested   OralExamSummary[] @relation("SummaryAttestedBy")

  // ── Post-defense ──
  manuscriptExtensionsApproved ManuscriptSubmission[] @relation("ExtensionApprovedBy")
  elibraryEntriesApproved      ELibrary[]             @relation("ELibraryApprovedBy")

  // ── Document forms ──
  rapReportsGenerated      RapReport[]           @relation("RapReportGeneratedBy")
  rapReportSignatures      RapReportSignature[]
  adviserCertifications    AdviserCertification[] @relation("AdviserCertIssuer")
  researchVarSignatures    ResearchVarSignature[]
  expertEvalRequestsAssigned ExpertEvaluationRequest[] @relation("EvalRequestAssignedBy")

  // ── Admin & comms ──
  memosCreated             Memo[]             @relation("MemoCreatedBy")
  chatbotFaqsCreated       ChatbotFaq[]       @relation("FaqCreatedBy")
  schoolCalendarCreated    SchoolYearCalendar[] @relation("CalendarCreatedBy")
  systemSettingsModified   SystemSetting[]    @relation("SettingModifiedBy")
  auditLogsAsActor         AuditLog[]         @relation("AuditLogActor")
  emailTemplatesCreated    EmailTemplate[]    @relation("EmailTemplateCreatedBy")
  emailTemplatesUpdated    EmailTemplate[]    @relation("EmailTemplateUpdatedBy")

  @@map("users")
}

enum UserRole {
  ADMIN
  STUDENT
  PANELIST
  CUSTOM
  APPLICANT

  @@map("user_role")
}

// ── students  [UPDATED v8: +5 columns] ──────────────────────────────────
model Student {
  id                      String           @id @default(uuid()) @map("student_id")
  userId                  String           @unique @map("user_id")
  studentNumber           String?          @unique @map("student_number")
  cellphone               String?
  programId               String           @map("program_id")
  admissionStatus         AdmissionStatus  @default(APPLICANT) @map("admission_status")
  enrollmentDate          DateTime?        @db.Date @map("enrollment_date")
  residencyStartDate      DateTime?        @db.Date @map("residency_start_date")
  curriculumType          CurriculumType?  @map("curriculum_type")
  // v8 ── Pinnacle-first registration & alignment check
  pinnacleApplicantId     String?          @map("pinnacle_applicant_id")
  undergraduateProgramId     String?          @map("undergraduate_program_id")
  dateOfBirth             DateTime?        @db.Date @map("date_of_birth")
  isProgramAligned        Boolean?         @map("is_program_aligned")
  alignmentStatus         AlignmentStatus? @map("alignment_status")
  // ── Pre-requisites ──
  previousMastersProgramId   String?          @map("previous_masters_program_id")
  previousMastersProgram     Program?         @relation("PreviousMastersProgram", fields: [previousMastersProgramId], references: [id])
  // COR OCR sync
  corExtractedYearLevel   String?          @map("cor_extracted_year_level")
  corExtractedScholarship String?          @map("cor_extracted_scholarship")
  lastCorSyncAt           DateTime?        @map("last_cor_sync_at")
  createdAt               DateTime         @default(now()) @map("created_at")

  // ── Relations ──
  user                    User                       @relation(fields: [userId], references: [id])
  program                 Program                    @relation(fields: [programId], references: [id])
  undergraduateProgram    UndergraduateProgram?      @relation(fields: [undergraduateProgramId], references: [id])
  residencyTracking       ResidencyTracking?
  curriculumWaivers       CurriculumWaiver[]
  bridgingWaiver          ApplicantBridgingWaiver?
  examApplications        EntranceExamApplication[]
  compExamRecords         CompExamRecord[]
  corUploads              CorUpload[]
  corRecords              CorRecord[]
  studentRequirements     StudentRequirement[]
  adviserRequests         AdviserRequest[]
  adviserAssignments      AdviserAssignment[]        @relation("AdviserAssignmentStudent")
  thesisRecords           ThesisRecord[]
  acknowledgementReceipts AcknowledgementReceipt[]
  studentFiles            StudentFile[]
  studentCalendars        StudentCalendar[]
  

  @@map("students")
}

enum AdmissionStatus {
  APPLICANT
  ENROLLED
  GRADUATED
  DISMISSED

  @@map("admission_status")
}

enum CurriculumType {
  OLD
  NEW

  @@map("curriculum_type")
}

enum AlignmentStatus {
  ALIGNED
  PENDING_WAIVER
  CLEARED

  @@map("alignment_status")
}

// ── panelists  [UPDATED v7: +is_available_as_adviser] ───────────────────
model Panelist {
  id                           String  @id @default(uuid()) @map("panelist_id")
  userId                       String  @unique @map("user_id")
  highestEducationalAttainment String? @map("highest_educational_attainment")
  officeAffiliation            String? @map("office_affiliation")
  specialization               String?
  isExternal                   Boolean @default(false) @map("is_external")
  isAvailableAsAdviser         Boolean @default(true)  @map("is_available_as_adviser")
  isActive                     Boolean @default(true)  @map("is_active")
  createdAt                    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("panelists")
}

// ── programs ─────────────────────────────────────────────────────────────
model Program {
  id                String      @id @default(uuid()) @map("program_id")
  programName       String      @map("program_name")
  programType       ProgramType @map("program_type")
  department        String?
  maxResidencyYears Int?        @map("max_residency_years")
  createdAt         DateTime    @default(now()) @map("created_at")

  students              Student[]
  examSlots             ExamSlot[]
  bridgingWaivers       ApplicantBridgingWaiver[] @relation("BridgingIntendedProgram")
  examApplications      EntranceExamApplication[]
  requirementsChecklist RequirementsChecklist[]
  memos                 Memo[]

  studentsAsPreviousMasters  Student[]        @relation("PreviousMastersProgram")

  @@map("programs")
}

enum ProgramType {
  MASTERS
  DOCTORAL

  @@map("program_type")
}

// ── undergraduate_programs ────────────────────────────────────────────────
model UndergraduateProgram {
  id          String   @id @default(uuid()) @map("ug_program_id")
  programName String   @unique @map("program_name")
  acronym     String?
  college     String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // ── Relations ──
  students        Student[]
  bridgingWaivers ApplicantBridgingWaiver[] @relation("BridgingUndergradProgram")

  @@map("undergraduate_programs")
}

// ── custom_roles ─────────────────────────────────────────────────────────
model CustomRole {
  id              String   @id @default(uuid()) @map("role_id")
  roleName        String   @unique @map("role_name")
  roleDescription String?  @map("role_description")
  createdById     String   @map("created_by")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdBy     User                @relation("CustomRoleCreatedBy", fields: [createdById], references: [id])
  users         User[]              @relation("UserCustomRole")
  featureAccess RoleFeatureAccess[]

  @@map("custom_roles")
}

// ── role_feature_access ──────────────────────────────────────────────────
model RoleFeatureAccess {
  id           String   @id @default(uuid()) @map("access_id")
  roleId       String   @map("role_id")
  featureKey   String   @map("feature_key")
  featureLabel String?  @map("feature_label")
  canView      Boolean  @default(false) @map("can_view")
  canEdit      Boolean  @default(false) @map("can_edit")
  createdAt    DateTime @default(now()) @map("created_at")

  role CustomRole @relation(fields: [roleId], references: [id])

  @@map("role_feature_access")
}

// ── residency_tracking ───────────────────────────────────────────────────
model ResidencyTracking {
  id            String    @id @default(uuid()) @map("residency_id")
  studentId     String    @unique @map("student_id")
  startDate     DateTime  @db.Date @map("start_date")
  maxYears      Int       @map("max_years")
  warningSentAt DateTime? @map("warning_sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id])

  @@map("residency_tracking")
}

// ── curriculum_waivers ───────────────────────────────────────────────────
// Handles enrolled students switching curriculum tracks (old vs. new).
// Distinct from applicant_bridging_waivers which is applicant-only.
model CurriculumWaiver {
  id              String       @id @default(uuid()) @map("waiver_id")
  studentId       String       @map("student_id")
  waiverDate      DateTime     @db.Date @map("waiver_date")
  recommendedById String       @map("recommended_by")
  approvedById    String       @map("approved_by")
  status          WaiverStatus @default(PENDING)
  createdAt       DateTime     @default(now()) @map("created_at")

  student       Student @relation(fields: [studentId], references: [id])
  recommendedBy User    @relation("WaiverRecommendedBy", fields: [recommendedById], references: [id])
  approvedBy    User    @relation("WaiverApprovedBy", fields: [approvedById], references: [id])

  @@map("curriculum_waivers")
}

enum WaiverStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("waiver_status")
}

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 2 — APPLICANT PIPELINE  (6 tables)  [MAJOR CHANGES v8]
// exam_slots · applicant_bridging_waivers(NEW) · entrance_exam_applications
// entrance_exam_scores · comp_exam_records · notifications
// ═══════════════════════════════════════════════════════════════════════════

// ── exam_slots ───────────────────────────────────────────────────────────
model ExamSlot {
  id         String   @id @default(uuid()) @map("slot_id")
  programId  String   @map("program_id")
  examDate   DateTime @db.Date @map("exam_date")
  examTime   DateTime @db.Time @map("exam_time")
  maxSlots   Int      @map("max_slots")
  slotsTaken Int      @default(0) @map("slots_taken")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  program          Program                   @relation(fields: [programId], references: [id])
  examApplications EntranceExamApplication[]

  @@map("exam_slots")
}

// ── applicant_bridging_waivers  [NEW v8] ────────────────────────────────
// Sole bridging entity. Applies exclusively to Applicant role during the
// automated Program Alignment Check. Not used for enrolled students.
model ApplicantBridgingWaiver {
  id                     String               @id @default(uuid()) @map("waiver_id")
  studentId              String               @unique @map("student_id")
  undergraduateProgramId    String?              @map("undergraduate_program_id")
  intendedProgramId      String               @map("intended_program_id")
  waiverFormDownloadedAt DateTime?            @map("waiver_form_downloaded_at")
  status                 BridgingWaiverStatus @default(PENDING)
  validatedById          String?              @map("validated_by")
  validatedAt            DateTime?            @map("validated_at")
  adminNotes             String?              @map("admin_notes")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  student         Student  @relation(fields: [studentId], references: [id])
  intendedProgram Program  @relation("BridgingIntendedProgram", fields: [intendedProgramId], references: [id])
  validatedBy     User?    @relation("BridgingWaiverValidatedBy", fields: [validatedById], references: [id])
  undergraduateProgram UndergraduateProgram?  @relation("BridgingUndergradProgram", fields: [undergraduateProgramId], references: [id])

  @@map("applicant_bridging_waivers")
}

enum BridgingWaiverStatus {
  PENDING
  VALIDATED
  REJECTED

  @@map("bridging_waiver_status")
}

// ── entrance_exam_applications  [UPDATED v8: or_number/amount_paid removed] ──
model EntranceExamApplication {
  id              String        @id @default(uuid()) @map("application_id")
  studentId       String        @map("student_id")
  programId       String        @map("program_id")
  slotId          String        @map("slot_id")
  strikeCount     Int           @default(0) @map("strike_count")
  applicationDate DateTime      @db.Date @map("application_date")
  examDate        DateTime?     @db.Date @map("exam_date")
  examTime        DateTime?     @db.Time @map("exam_time")
  status          ExamAppStatus @default(PENDING)
  createdAt       DateTime      @default(now()) @map("created_at")

  student Student            @relation(fields: [studentId], references: [id])
  program Program            @relation(fields: [programId], references: [id])
  slot    ExamSlot           @relation(fields: [slotId], references: [id])
  score   EntranceExamScore?

  @@map("entrance_exam_applications")
}

enum ExamAppStatus {
  PENDING
  APPROVED
  TAKEN
  PASSED
  FAILED
  DISQUALIFIED

  @@map("exam_app_status")
}

// ── entrance_exam_scores ─────────────────────────────────────────────────
model EntranceExamScore {
  id                  String     @id @default(uuid()) @map("score_id")
  applicationId       String     @unique @map("application_id")
  gradedById          String     @map("graded_by")
  multipleChoiceScore Decimal?   @map("multiple_choice_score")
  essayScore          Decimal?   @map("essay_score")
  totalScore          Decimal?   @map("total_score")
  status              ExamResult
  createdAt           DateTime   @default(now()) @map("created_at")

  application EntranceExamApplication @relation(fields: [applicationId], references: [id])
  gradedBy    User                    @relation("ExamScoreGradedBy", fields: [gradedById], references: [id])

  @@map("entrance_exam_scores")
}

enum ExamResult {
  PASSED
  FAILED

  @@map("exam_result")
}

// ── comp_exam_records ────────────────────────────────────────────────────
// Status-only academic record. Does NOT gate portal access or promotion.
// Credentials are issued on ECAT pass + COR verification only.
model CompExamRecord {
  id        String         @id @default(uuid()) @map("comp_exam_id")
  studentId String         @map("student_id")
  status    CompExamStatus @default(PENDING)
  createdAt DateTime       @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id])

  @@map("comp_exam_records")
}

enum CompExamStatus {
  PENDING
  PASSED
  FAILED

  @@map("comp_exam_status")
}

// ── notifications  (shared: Applicant Pipeline + Admin & Comms) ──────────
model Notification {
  id                String           @id @default(uuid()) @map("notification_id")
  userId            String           @map("user_id")
  title             String
  message           String           @db.Text
  type              NotificationType
  isRead            Boolean          @default(false) @map("is_read")
  relatedRecordType String?          @map("related_record_type")
  relatedRecordId   String?          @map("related_record_id")
  createdAt         DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

enum NotificationType {
  RESIDENCY_WARNING
  DEFENSE_SCHEDULE
  MEMO
  REQUIREMENT_STATUS
  CERT_READY
  EXAM_RESULT
  CREDENTIAL_DISPATCH
  ESIGN_REQUEST
  ADVISER_ASSIGNMENT
  PLAGIARISM_RESULT
  DEFENSE_ASSIGNMENT

  @@map("notification_type")
}

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 3 — COR & OCR PIPELINE  (2 tables)
// cor_uploads · cor_records
// ═══════════════════════════════════════════════════════════════════════════

// ── cor_uploads ──────────────────────────────────────────────────────────
model CorUpload {
  id               String    @id @default(uuid()) @map("cor_upload_id")
  studentId        String    @map("student_id")
  filePath         String    @map("file_path")
  originalFilename String?   @map("original_filename")
  ocrStatus        OcrStatus @default(PENDING) @map("ocr_status")
  ocrErrorMessage  String?   @map("ocr_error_message")
  uploadedAt       DateTime  @map("uploaded_at")
  processedAt      DateTime? @map("processed_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  student   Student    @relation(fields: [studentId], references: [id])
  corRecord CorRecord?

  @@map("cor_uploads")
}

enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED

  @@map("ocr_status")
}

// ── cor_records  (authoritative: full 28-field version) ─────────────────
model CorRecord {
  id                           String              @id @default(uuid()) @map("cor_record_id")
  corUploadId                  String              @unique @map("cor_upload_id")
  studentId                    String              @map("student_id")
  registrationNumber           String?             @map("registration_number")
  academicYear                 String?             @map("academic_year")
  semester                     CorSemester?
  college                      String?
  extractedProgramName         String?             @map("extracted_program_name")
  extractedCurriculumYear      String?             @map("extracted_curriculum_year")
  extractedYearLevel           String?             @map("extracted_year_level")
  extractedScholarshipDiscount String?             @map("extracted_scholarship_discount")
  totalAssessment              Decimal?            @map("total_assessment")
  lessFinancialAid             Decimal?            @map("less_financial_aid")
  netAssessed                  Decimal?            @map("net_assessed")
  creditMemo                   Decimal?            @map("credit_memo")
  totalDiscount                Decimal?            @map("total_discount")
  totalPayment                 Decimal?            @map("total_payment")
  outstandingBalance           Decimal?            @map("outstanding_balance")
  payment1stDue                Decimal?            @map("payment_1st_due")
  payment2ndDue                Decimal?            @map("payment_2nd_due")
  payment3rdDue                Decimal?            @map("payment_3rd_due")
  paymentValidationDate        DateTime?           @db.Date @map("payment_validation_date")
  officialReceiptNumber        String?             @map("official_receipt_number")
  approvedByRegistrar          String?             @map("approved_by_registrar")
  isAdminVerified              Boolean             @default(false) @map("is_admin_verified")
  verificationMethod           VerificationMethod? @map("verification_method")
  verifiedById                 String?             @map("verified_by")
  verifiedAt                   DateTime?           @map("verified_at")
  createdAt                    DateTime            @default(now()) @map("created_at")

  corUpload  CorUpload @relation(fields: [corUploadId], references: [id])
  student    Student   @relation(fields: [studentId], references: [id])
  verifiedBy User?     @relation("CorRecordVerifiedBy", fields: [verifiedById], references: [id])

  @@map("cor_records")
}

enum CorSemester {
  FIRST_SEM  @map("1st")
  SECOND_SEM @map("2nd")
  SUMMER     @map("summer")

  @@map("cor_semester")
}

enum VerificationMethod {
  QR_AUTO      @map("qr_auto")
  OCR_AUTO     @map("ocr_auto")
  ADMIN_MANUAL @map("admin_manual")

  @@map("verification_method")
}

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 4 — REQUIREMENTS  (2 tables)
// requirements_checklist · student_requirements
// ═══════════════════════════════════════════════════════════════════════════

// ── requirements_checklist ───────────────────────────────────────────────
model RequirementsChecklist {
  id              String           @id @default(uuid()) @map("requirement_id")
  programId       String           @map("program_id")
  stage           RequirementStage
  requirementName String           @map("requirement_name")
  description     String?
  isMandatory     Boolean          @default(true) @map("is_mandatory")
  createdAt       DateTime         @default(now()) @map("created_at")

  program             Program              @relation(fields: [programId], references: [id])
  studentRequirements StudentRequirement[]

  @@map("requirements_checklist")
}

enum RequirementStage {
  ADMISSION
  TITLE_DEFENSE
  PROPOSAL_DEFENSE
  FINAL_DEFENSE
  GRADUATION

  @@map("requirement_stage")
}

// ── student_requirements ─────────────────────────────────────────────────
model StudentRequirement {
  id             String            @id @default(uuid()) @map("student_req_id")
  studentId      String            @map("student_id")
  requirementId  String            @map("requirement_id")
  filePath       String?           @map("file_path")
  submissionDate DateTime?         @db.Date @map("submission_date")
  status         RequirementStatus @default(PENDING)
  reviewedById   String            @map("reviewed_by")
  reviewNotes    String?           @map("review_notes")
  createdAt      DateTime          @default(now()) @map("created_at")

  student     Student               @relation(fields: [studentId], references: [id])
  requirement RequirementsChecklist @relation(fields: [requirementId], references: [id])
  reviewedBy  User                  @relation("RequirementReviewedBy", fields: [reviewedById], references: [id])

  @@map("student_requirements")
}

enum RequirementStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("requirement_status")
}

// ═══════════════════════════════════════════════════════════════════════════
// MODULE 5 — THESIS & DEFENSE  (9 tables)
// adviser_requests · adviser_assignments · thesis_records · thesis_titles
// thesis_documents · defense_schedules · panel_assignments ·
// oral_exam_scores · oral_exam_summary
// ═══════════════════════════════════════════════════════════════════════════

// ── adviser_requests  [UPDATED v7] ───────────────────────────────────────
model AdviserRequest {
  id                 String        @id @default(uuid()) @map("adviser_req_id")
  studentId          String        @map("student_id")
  requestedAdviserId String        @map("requested_adviser_id")
  reason             String?
  status             RequestStatus @default(PENDING)
  approvedById       String        @map("approved_by")
  requestDate        DateTime      @db.Date @map("request_date")
  createdAt          DateTime      @default(now()) @map("created_at")

  student          Student @relation(fields: [studentId], references: [id])
  requestedAdviser User    @relation("AdviserRequestedPanelist", fields: [requestedAdviserId], references: [id])
  approvedBy       User    @relation("AdviserRequestApprovedBy", fields: [approvedById], references: [id])

  @@map("adviser_requests")
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("request_status")
}

// ── adviser_assignments  [UPDATED v7: renamed from faculty_id → adviser_id] ──
model AdviserAssignment {
  id           String   @id @default(uuid()) @map("assignment_id")
  studentId    String   @map("student_id")
  adviserId    String   @map("adviser_id")
  assignedDate DateTime @db.Date @map("assigned_date")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  student       Student       @relation("AdviserAssignmentStudent", fields: [studentId], references: [id])
